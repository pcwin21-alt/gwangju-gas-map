# 공공데이터포털 API 키 (data.go.kr 회원가입 후 발급)
# 온누리상품권 가맹점 현황 데이터셋 활용신청: https://www.data.go.kr/data/3060079/fileData.do
ONNURI_API_KEY=your_onnuri_api_key_here

# 카카오 Local API 키 (주소→좌표 변환, 좌표 누락 항목이 있을 때만 사용)
# 카카오 개발자센터: https://developers.kakao.com → REST API 키
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here

# 카카오맵 JavaScript SDK 앱 키 (지도 렌더링용)
# 카카오 개발자센터: https://developers.kakao.com → JavaScript 키
# GitHub Pages 배포 시 해당 도메인을 허용 도메인에 등록할 것
KAKAO_MAPS_APP_KEY=your_kakao_maps_app_key_here
